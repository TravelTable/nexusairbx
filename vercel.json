{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "nexusrbx.com"
        }
      ],
      "destination": "https://www.nexusrbx.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|_next/|static/|assets/|sitemaps/|sitemap\\.xml|robots\\.txt|favicon\\.ico|manifest\\.json).*)",
      "destination": "/api/render?path=/$1"
    }
  ],
  "functions": {
    "api/render.js": {
      "includeFiles": "{build/__spa-shell.html,build/index.html,public-frontend/data/generated/**}"
    }
  }
}
