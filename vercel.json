{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "headers": [
    {
      "source": "/connector/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, HEAD, OPTIONS" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "downloads.nexusrbx.com"
        }
      ],
      "destination": "https://www.nexusrbx.com/downloads",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "nexusrbx.com"
        }
      ],
      "destination": "https://www.nexusrbx.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/connector/:path*",
      "has": [
        {
          "type": "host",
          "value": "downloads.nexusrbx.com"
        }
      ],
      "destination": "https://onzdkc69myiiqxmi.public.blob.vercel-storage.com/connector/:path*"
    },
    {
      "source": "/",
      "destination": "/api/render?path=/"
    },
    {
      "source": "/downloads",
      "destination": "/api/render?path=/downloads"
    },
    {
      "source": "/docs",
      "destination": "/api/render?path=/docs"
    },
    {
      "source": "/docs/account",
      "destination": "/api/render?path=/docs/account"
    },
    {
