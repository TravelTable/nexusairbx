# Firebase App Check reCAPTCHA v3 public site key.
REACT_APP_RECAPTCHA_SITE_KEY=6Ld2jU4tAAAAAJxnNADHP1rJW-TvG98gE1YRKIFU

# Local development only. Register an explicit Firebase App Check debug token;
# never set this in production.
REACT_APP_APP_CHECK_DEBUG_TOKEN=

# Coalesce in-progress assistant message writes; clamped to 5-10 seconds.
REACT_APP_CHAT_PROGRESS_PERSIST_INTERVAL_MS=7500

# Prompt 2 canonical asset catalog rollout. Keep writes off until the Prompt 3
# operation-ledger orchestration and external-write verification gates ship.
REACT_APP_ASSET_PLATFORM_READS_ENABLED=false
REACT_APP_ASSET_PLATFORM_WRITES_ENABLED=false

# Prompt 3 durable task-runtime rollout. These are presentation/read adapters;
# the backend execution owner remains authoritative. Keep canonical surfaces off
# until the corresponding backend migration stage is enabled and observed.
REACT_APP_NEW_TASK_RUNTIME=false
REACT_APP_DURABLE_STUDIO_COMMANDS=false
REACT_APP_AGENT_CONTEXT_ASSEMBLER=false
REACT_APP_DYNAMIC_CAPABILITY_LOADING=false
REACT_APP_NEW_PLANNING_MODE=false
REACT_APP_CONVERSATIONAL_TASK_FEED=false
REACT_APP_TASK_RECOVERY=false
REACT_APP_VERIFIED_COMPLETION=false
REACT_APP_LEGACY_AGENT_FALLBACK=true
