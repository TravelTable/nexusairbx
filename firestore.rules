rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isBoundedList(max) {
      return request.query.limit != null
        && request.query.limit <= max
        && request.query.offset == null;
    }

    function teamMemberPath(teamId, uid) {
      return /databases/$(database)/documents/teams/$(teamId)/members/$(uid);
    }

    function isTeamMember(teamId) {
      return isSignedIn() && exists(teamMemberPath(teamId, request.auth.uid));
    }

    function isTeamAdmin(teamId) {
      return isSignedIn() && get(teamMemberPath(teamId, request.auth.uid)).data.role in ['owner', 'admin'];
    }

    match /users/{uid} {
      allow get, create, update, delete: if isOwner(uid);
      allow list: if false;

      match /{document=**} {
        allow get, create, update, delete: if isOwner(uid);
        allow list: if isOwner(uid) && isBoundedList(200);
      }
    }

    match /teams/{teamId} {
      allow get: if isTeamMember(teamId);
      allow list, create: if false;
      allow update, delete: if isTeamAdmin(teamId);

      match /members/{memberId} {
        allow get: if isTeamMember(teamId);
        allow list: if isTeamMember(teamId) && isBoundedList(100);
        allow create, update, delete: if isTeamAdmin(teamId);
      }

      match /shared_artifacts/{artifactId} {
        allow get: if isTeamMember(teamId);
        allow list: if isTeamMember(teamId) && isBoundedList(100);
        allow create: if isTeamMember(teamId);
        allow update, delete: if isTeamAdmin(teamId);
      }

      match /projects/{projectId} {
        allow get, create, update, delete: if isTeamMember(teamId);
        allow list: if isTeamMember(teamId) && isBoundedList(100);
      }
    }

    match /customers/{uid} {
      allow get: if isOwner(uid);
      allow list, create, update, delete: if false;

      match /checkout_sessions/{sessionId} {
        allow get: if isOwner(uid);
        allow list, create, update, delete: if false;
      }

      match /portal_sessions/{sessionId} {
        allow get: if isOwner(uid);
        allow list, create, update, delete: if false;
      }

      match /subscriptions/{subscriptionId} {
        allow get: if isOwner(uid);
        allow list: if isOwner(uid) && isBoundedList(20);
        allow create, update, delete: if false;
      }
    }

    match /_productAnalyticsEvents/{eventId} {
      allow read, write: if false;
    }

    match /aiTelemetryEvents/{eventId} {
      allow read, write: if false;
    }

    match /_jobs/{jobId} {
      allow read: if false;
      allow write: if false;
    }

    match /_stream_sessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
