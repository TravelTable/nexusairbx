rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Firebase ID tokens carry this claim after the user reloads their token
    // following email verification.
    function isVerifiedUser(uid) {
      return isOwner(uid)
        && request.auth.token.email_verified == true;
    }

    function isBoundedList(max) {
      return request.query.limit != null
        && request.query.limit <= max;
    }

    function onlyChanges(allowed) {
      return request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly(allowed);
    }

    function isShortString(value, max) {
      return value is string && value.size() <= max;
    }

    function isNullableShortString(value, max) {
      return value == null || isShortString(value, max);
    }

    function isTimestamp(value) {
      return value is timestamp;
    }

    function hasOnlyUserDocumentFields() {
      return request.resource.data.keys().hasOnly([
        'title',
        'activeMode',
        'createdAt',
        'updatedAt',
        'lastMessage',
        'projectId',
        'studioTargetPreference',
        'lifecycle',
        'draftId',
        'chatId'
      ]);
    }

    function validChatMode(value) {
      return value in ['ask', 'chat', 'plan', 'agent', 'debug'];
    }

    function validChatLifecycle(value) {
      return value in ['draft', 'active', 'archived'];
    }

    function validStudioTargetPreference(value) {
      return value is map
        && value.keys().hasOnly(['targetId', 'placeId', 'label', 'updatedAt'])
        && (
          !value.keys().hasAny(['targetId'])
          || value.targetId == null
          || isShortString(value.targetId, 200)
        )
        && (
          !value.keys().hasAny(['placeId'])
          || value.placeId == null
          || isShortString(value.placeId, 80)
        )
        && (
          !value.keys().hasAny(['label'])
          || value.label == null
          || isShortString(value.label, 160)
        )
        && (
          !value.keys().hasAny(['updatedAt'])
          || value.updatedAt == null
          || isTimestamp(value.updatedAt)
        );
    }

    function validWorkflowTargeting(value) {
      return value is map
        && value.keys().hasOnly([
          'projectId',
          'projectName',
          'studioConnected',
          'studioTarget',
          'studioRequired',
          'studioSessionId',
          'placeId',
          'universeId'
        ])
        && (!value.keys().hasAny(['projectId']) || isNullableShortString(value.projectId, 180))
        && (!value.keys().hasAny(['projectName']) || isNullableShortString(value.projectName, 240))
        && (!value.keys().hasAny(['studioConnected']) || value.studioConnected is bool)
        && (!value.keys().hasAny(['studioTarget']) || value.studioTarget == null || validStudioTargetPreference(value.studioTarget))
        && (!value.keys().hasAny(['studioRequired']) || value.studioRequired is bool)
        && (!value.keys().hasAny(['studioSessionId']) || isNullableShortString(value.studioSessionId, 180))
        && (!value.keys().hasAny(['placeId']) || isNullableShortString(value.placeId, 80))
        && (!value.keys().hasAny(['universeId']) || isNullableShortString(value.universeId, 80));
    }

    function validClarificationAnswers(value) {
      return value == null || (value is map && value.keys().size() <= 50);
    }

    function validStructuredPlan(value) {
      return value == null || (
        value is map
        && value.keys().hasOnly([
          'schemaVersion',
          'sections',
          'implementationSteps',
          'verificationSteps',
          'lockedSectionIds',
          'targeting',
          'constraints',
          'assets',
          'capabilities',
          'assumptions',
          'templateId',
          'clarificationAnswers',
          'stagedExecution'
        ])
        && value.keys().hasAll(['schemaVersion', 'sections', 'targeting'])
        && value.schemaVersion == 'nexusrbx-workflow-plan-v3'
        && value.sections is list
        && value.sections.size() == 9
        && (!value.keys().hasAny(['implementationSteps']) || (value.implementationSteps is list && value.implementationSteps.size() <= 100))
        && (!value.keys().hasAny(['verificationSteps']) || (value.verificationSteps is list && value.verificationSteps.size() <= 100))
        && (!value.keys().hasAny(['lockedSectionIds']) || (value.lockedSectionIds is list && value.lockedSectionIds.size() <= 20))
        && validWorkflowTargeting(value.targeting)
        && (!value.keys().hasAny(['constraints']) || (value.constraints is list && value.constraints.size() <= 100))
        && (!value.keys().hasAny(['assets']) || (value.assets is list && value.assets.size() <= 100))
        && (!value.keys().hasAny(['capabilities']) || (value.capabilities is list && value.capabilities.size() <= 100))
        && (!value.keys().hasAny(['assumptions']) || (value.assumptions is list && value.assumptions.size() <= 100))
        && (!value.keys().hasAny(['templateId']) || isNullableShortString(value.templateId, 80))
        && (!value.keys().hasAny(['clarificationAnswers']) || validClarificationAnswers(value.clarificationAnswers))
        && (!value.keys().hasAny(['stagedExecution']) || (
          value.stagedExecution is map
          && value.stagedExecution.keys().hasOnly(['recommended', 'reason', 'stages'])
          && (!value.stagedExecution.keys().hasAny(['recommended']) || value.stagedExecution.recommended is bool)
          && (!value.stagedExecution.keys().hasAny(['reason']) || isShortString(value.stagedExecution.reason, 1000))
          && (!value.stagedExecution.keys().hasAny(['stages']) || (value.stagedExecution.stages is list && value.stagedExecution.stages.size() <= 100))
        ))
      );
    }

    function validChatCreate() {
      return hasOnlyUserDocumentFields()
        && request.resource.data.keys().hasAll([
          'title',
          'createdAt',
          'updatedAt'
        ])
        && isShortString(request.resource.data.title, 160)
        && isTimestamp(request.resource.data.createdAt)
        && isTimestamp(request.resource.data.updatedAt)
        && (
          !request.resource.data.keys().hasAny(['activeMode'])
          || validChatMode(request.resource.data.activeMode)
        )
        && (
          !request.resource.data.keys().hasAny(['lastMessage'])
          || isShortString(request.resource.data.lastMessage, 500)
        )
        && (
          !request.resource.data.keys().hasAny(['projectId'])
          || isNullableShortString(request.resource.data.projectId, 120)
        )
        && (
          !request.resource.data.keys().hasAny(['studioTargetPreference'])
          || validStudioTargetPreference(request.resource.data.studioTargetPreference)
        )
        && (
          !request.resource.data.keys().hasAny(['lifecycle'])
          || validChatLifecycle(request.resource.data.lifecycle)
        )
        && (
          !request.resource.data.keys().hasAny(['draftId'])
          || isShortString(request.resource.data.draftId, 120)
        )
        && (
          !request.resource.data.keys().hasAny(['chatId'])
          || isShortString(request.resource.data.chatId, 120)
        );
    }

    function validChatUpdate() {
      return onlyChanges([
        'title',
        'activeMode',
        'updatedAt',
        'lastMessage',
        'projectId',
        'studioTargetPreference',
        'lifecycle'
      ])
        && (
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['title'])
          || isShortString(request.resource.data.title, 160)
        )
        && (
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['activeMode'])
          || validChatMode(request.resource.data.activeMode)
        )
        && (
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['lastMessage'])
          || isShortString(request.resource.data.lastMessage, 500)
        )
        && (
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['projectId'])
          || isNullableShortString(request.resource.data.projectId, 120)
        )
        && (
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['studioTargetPreference'])
          || validStudioTargetPreference(request.resource.data.studioTargetPreference)
        )
        && (
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['lifecycle'])
          || validChatLifecycle(request.resource.data.lifecycle)
        )
        && (
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['updatedAt'])
          || isTimestamp(request.resource.data.updatedAt)
        );
    }

    function hasOnlyMessageFields() {
      return request.resource.data.keys().hasOnly([
        'role',
        'content',
        'attachments',
        'createdAt',
        'updatedAt',
        'requestId',
        'stage',
        'pending',
        'jobId',
        'runId',
        'isAutoExecuting',
        'metadata',
        'steps',
        'errorCode',
        'error',
        'code',
        'patchApplied',
        'intent',
        'explanation',
        'questions',
        'originPrompt',
        'planId',
        'classification',
        'aiSummary',
        'aiSteps',
        'aiAssumptions',
        'planMarkdown',
        'planSteps',
        'answers',
        'summary',
        'thought',
        'title',
        'projectId',
        'versionNumber',
        'artifactId',
        'options',
        'plan',
        'files',
        'revision',
        'setupSteps',
        'testingSteps',
        'securityNotes',
        'warnings',
        'studioConnected',
        'studioTarget',
        'targeting',
        'requestMode',
        'templateId',
        'planVersion',
        'planHash',
        'structuredPlan',
        'capabilities',
        'clarificationAnswers',
        'taskId',
        'queuePosition'
      ]);
    }

    function hasOnlyPlanMessageFields() {
      return request.resource.data.keys().hasOnly([
        'role',
        'stage',
        'planId',
        'planVersion',
        'planHash',
        'classification',
        'aiSummary',
        'aiSteps',
        'aiAssumptions',
        'planMarkdown',
        'planSteps',
        'structuredPlan',
        'capabilities',
        'clarificationAnswers',
        'templateId',
        'projectId',
        'studioConnected',
        'studioTarget',
        'targeting',
        'originPrompt',
        'attachments',
        'createdAt',
        'updatedAt',
        'requestId'
      ]);
    }

    function validPlanMessagePayload() {
      return hasOnlyPlanMessageFields()
        && request.resource.data.keys().hasAll([
          'role', 'stage', 'planId', 'planVersion', 'planHash', 'classification',
          'aiSummary', 'aiSteps', 'aiAssumptions', 'planMarkdown', 'planSteps',
          'structuredPlan', 'capabilities', 'clarificationAnswers', 'templateId',
          'projectId', 'studioConnected', 'studioTarget', 'targeting', 'originPrompt',
          'attachments', 'createdAt', 'requestId'
        ])
        && request.resource.data.role == 'assistant'
        && request.resource.data.stage == 'plan'
        && isTimestamp(request.resource.data.createdAt)
        && (!request.resource.data.keys().hasAny(['updatedAt']) || isTimestamp(request.resource.data.updatedAt))
        && request.resource.data.structuredPlan is map
          && request.resource.data.structuredPlan.keys().hasOnly([
            'schemaVersion', 'sections', 'implementationSteps', 'verificationSteps',
            'lockedSectionIds', 'targeting', 'constraints', 'assets', 'capabilities',
            'assumptions', 'templateId', 'clarificationAnswers', 'stagedExecution'
          ])
          && request.resource.data.structuredPlan.schemaVersion == 'nexusrbx-workflow-plan-v3'
          && request.resource.data.structuredPlan.sections is list
          && request.resource.data.structuredPlan.sections.size() == 9
        && request.resource.data.capabilities is list && request.resource.data.capabilities.size() <= 100
        && validWorkflowTargeting(request.resource.data.targeting)
        && isNullableShortString(request.resource.data.planId, 180)
        && request.resource.data.planVersion is int && request.resource.data.planVersion >= 1 && request.resource.data.planVersion <= 10000
        && isShortString(request.resource.data.planHash, 256)
        && isShortString(request.resource.data.classification, 80)
        && isShortString(request.resource.data.aiSummary, 30000)
        && request.resource.data.aiSteps is list && request.resource.data.aiSteps.size() <= 100
        && request.resource.data.aiAssumptions is list && request.resource.data.aiAssumptions.size() <= 100
        && isShortString(request.resource.data.planMarkdown, 60000)
        && request.resource.data.planSteps is list && request.resource.data.planSteps.size() <= 100
        && validClarificationAnswers(request.resource.data.clarificationAnswers)
        && isNullableShortString(request.resource.data.templateId, 80)
        && isNullableShortString(request.resource.data.projectId, 180)
        && request.resource.data.studioConnected is bool
        && (request.resource.data.studioTarget == null || validStudioTargetPreference(request.resource.data.studioTarget))
        && isShortString(request.resource.data.originPrompt, 30000)
        && request.resource.data.attachments is list && request.resource.data.attachments.size() <= 5
        && isShortString(request.resource.data.requestId, 180);
    }

    function isPlanMessage() {
      return request.resource.data.keys().hasAny(['stage'])
        && request.resource.data.stage == 'plan';
    }

    function validMessageCreate() {
      return isPlanMessage()
        ? (request.resource.data.keys().hasAny(['structuredPlan'])
            ? validPlanMessagePayload()
            : validMessagePayload())
        : validMessagePayload();
    }

    function validMessagePayload() {
      return hasOnlyMessageFields()
        && request.resource.data.keys().hasAll([
          'role',
          'createdAt'
        ])
        && request.resource.data.role in [
          'user',
          'assistant'
        ]
        && isTimestamp(request.resource.data.createdAt)
        && (
          !request.resource.data.keys().hasAny(['updatedAt'])
          || isTimestamp(request.resource.data.updatedAt)
        )
        && (
          !request.resource.data.keys().hasAny(['content'])
          || isShortString(request.resource.data.content, 60000)
        )
        && (
          !request.resource.data.keys().hasAny(['code'])
          || isShortString(request.resource.data.code, 200000)
        )
        && (
          !request.resource.data.keys().hasAny(['explanation'])
          || isShortString(request.resource.data.explanation, 30000)
        )
        && (
          !request.resource.data.keys().hasAny(['originPrompt'])
          || isShortString(request.resource.data.originPrompt, 30000)
        )
        && (
          !request.resource.data.keys().hasAny(['planMarkdown'])
          || isShortString(request.resource.data.planMarkdown, 60000)
        )
        && (
          !request.resource.data.keys().hasAny(['attachments'])
          || (
            request.resource.data.attachments is list
            && request.resource.data.attachments.size() <= 5
          )
        )
        && (!request.resource.data.keys().hasAny(['projectId']) || isNullableShortString(request.resource.data.projectId, 180))
        && (!request.resource.data.keys().hasAny(['studioConnected']) || request.resource.data.studioConnected is bool)
        && (!request.resource.data.keys().hasAny(['studioTarget']) || request.resource.data.studioTarget == null || validStudioTargetPreference(request.resource.data.studioTarget))
        && (!request.resource.data.keys().hasAny(['targeting']) || validWorkflowTargeting(request.resource.data.targeting))
        && (!request.resource.data.keys().hasAny(['requestMode']) || validChatMode(request.resource.data.requestMode))
        && (!request.resource.data.keys().hasAny(['templateId']) || isNullableShortString(request.resource.data.templateId, 80))
        && (!request.resource.data.keys().hasAny(['planVersion']) || (request.resource.data.planVersion is int && request.resource.data.planVersion >= 1 && request.resource.data.planVersion <= 10000))
        && (!request.resource.data.keys().hasAny(['planHash']) || isShortString(request.resource.data.planHash, 256))
        && (!request.resource.data.keys().hasAny(['structuredPlan']) || validStructuredPlan(request.resource.data.structuredPlan))
        && (!request.resource.data.keys().hasAny(['capabilities']) || (request.resource.data.capabilities is list && request.resource.data.capabilities.size() <= 100))
        && (!request.resource.data.keys().hasAny(['clarificationAnswers']) || validClarificationAnswers(request.resource.data.clarificationAnswers))
        && (!request.resource.data.keys().hasAny(['questions']) || (request.resource.data.questions is list && request.resource.data.questions.size() <= 3))
        && (!request.resource.data.keys().hasAny(['aiSteps']) || (request.resource.data.aiSteps is list && request.resource.data.aiSteps.size() <= 100))
        && (!request.resource.data.keys().hasAny(['aiAssumptions']) || (request.resource.data.aiAssumptions is list && request.resource.data.aiAssumptions.size() <= 100))
        && (!request.resource.data.keys().hasAny(['planSteps']) || (request.resource.data.planSteps is list && request.resource.data.planSteps.size() <= 100))
        && (!request.resource.data.keys().hasAny(['stage']) || isShortString(request.resource.data.stage, 80))
        && (!request.resource.data.keys().hasAny(['requestId']) || isShortString(request.resource.data.requestId, 180))
        && (!request.resource.data.keys().hasAny(['planId']) || isNullableShortString(request.resource.data.planId, 180))
        && (!request.resource.data.keys().hasAny(['taskId']) || isNullableShortString(request.resource.data.taskId, 180))
        && (!request.resource.data.keys().hasAny(['queuePosition']) || request.resource.data.queuePosition == null || (request.resource.data.queuePosition is int && request.resource.data.queuePosition >= 1 && request.resource.data.queuePosition <= 100000));
    }

    function validMessageUpdate() {
      return onlyChanges([
        'content',
        'attachments',
        'updatedAt',
        'stage',
        'pending',
        'jobId',
        'runId',
        'isAutoExecuting',
        'metadata',
        'steps',
        'errorCode',
        'error',
        'code',
        'patchApplied',
        'intent',
        'explanation',
        'questions',
        'originPrompt',
        'planId',
        'classification',
        'aiSummary',
        'aiSteps',
        'aiAssumptions',
        'planMarkdown',
        'planSteps',
        'answers',
        'summary',
        'thought',
        'title',
        'projectId',
        'versionNumber',
        'artifactId',
        'options',
        'plan',
        'files',
        'revision',
        'setupSteps',
        'testingSteps',
        'securityNotes',
        'warnings',
        'studioConnected',
        'studioTarget',
        'targeting',
        'requestMode',
        'templateId',
        'planVersion',
        'planHash',
        'structuredPlan',
        'capabilities',
        'clarificationAnswers',
        'taskId',
        'queuePosition'
      ])
        && validMessageCreate();
    }

    function hasOnlyScriptFields() {
      return request.resource.data.keys().hasOnly([
        'title',
        'chatId',
        'createdAt',
        'updatedAt',
        'type'
      ]);
    }

    function validScriptCreate() {
      return hasOnlyScriptFields()
        && request.resource.data.keys().hasAll([
          'title',
          'createdAt',
          'updatedAt'
        ])
        && isShortString(request.resource.data.title, 160)
        && isTimestamp(request.resource.data.createdAt)
        && isTimestamp(request.resource.data.updatedAt)
        && (
          !request.resource.data.keys().hasAny(['chatId'])
          || isShortString(request.resource.data.chatId, 200)
        )
        && (
          !request.resource.data.keys().hasAny(['type'])
          || isShortString(request.resource.data.type, 80)
        );
    }

    function validScriptUpdate() {
      return onlyChanges([
        'title',
        'chatId',
        'updatedAt',
        'type'
      ])
        && (
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['title'])
          || isShortString(request.resource.data.title, 160)
        )
        && (
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['chatId'])
          || isShortString(request.resource.data.chatId, 200)
        )
        && (
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['type'])
          || isShortString(request.resource.data.type, 80)
        )
        && (
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['updatedAt'])
          || isTimestamp(request.resource.data.updatedAt)
        );
    }

    function validScriptVersion() {
      return request.resource.data.keys().hasOnly([
        'versionNumber',
        'code',
        'explanation',
        'createdAt'
      ])
        && request.resource.data.keys().hasAll([
          'code',
          'createdAt'
        ])
        && request.resource.data.code is string
        && request.resource.data.code.size() <= 200000
        && isTimestamp(request.resource.data.createdAt)
        && (
          !request.resource.data.keys().hasAny(['versionNumber'])
          || (
            request.resource.data.versionNumber is int
            && request.resource.data.versionNumber >= 1
            && request.resource.data.versionNumber <= 100000
          )
        )
        && (
          !request.resource.data.keys().hasAny(['explanation'])
          || isShortString(request.resource.data.explanation, 30000)
        );
    }

    // Root user documents are controlled by the backend.
    // Users cannot change their own admin, plan, billing, Stripe,
    // entitlement, credit or usage fields.
    match /users/{uid} {
      allow get: if isOwner(uid);

      allow list, create, update, delete: if false;

      match /chats/{chatId} {
        allow get: if isOwner(uid);

        allow list: if isOwner(uid)
          && isBoundedList(100);

        allow create: if isVerifiedUser(uid)
          && validChatCreate();

        allow update: if isVerifiedUser(uid)
          && validChatUpdate();

        allow delete: if isVerifiedUser(uid);

        match /messages/{messageId} {
          allow get: if isOwner(uid);

          allow list: if isOwner(uid)
            && isBoundedList(300);

          allow create: if isVerifiedUser(uid)
            && validMessageCreate();

          allow update: if isVerifiedUser(uid)
            && validMessageUpdate();

          allow delete: if isVerifiedUser(uid);
        }

        // Project snapshots are created by trusted backend code.
        match /project/{documentId} {
          allow get: if isOwner(uid);

          allow list, create, update, delete: if false;
        }
      }

      match /scripts/{scriptId} {
        allow get: if isOwner(uid);

        allow list: if isOwner(uid)
          && isBoundedList(100);

        allow create: if isVerifiedUser(uid)
          && validScriptCreate();

        allow update: if isVerifiedUser(uid)
          && validScriptUpdate();

        allow delete: if isVerifiedUser(uid);

        match /versions/{versionId} {
          allow get: if isOwner(uid);

          allow list: if isOwner(uid)
            && isBoundedList(100);

          allow create: if isVerifiedUser(uid)
            && validScriptVersion();

          allow update, delete: if false;
        }
      }

      // Billing information is displayed to the owner but written by
      // trusted backend code.
      match /billing/{documentId} {
        allow get: if isOwner(uid);

        allow list, create, update, delete: if false;
      }

      // Server-managed project information.
      match /project/{documentId} {
        allow get: if isOwner(uid);

        allow list, create, update, delete: if false;
      }

      match /custom_modes/{documentId} {
        allow get: if isOwner(uid);

        allow list: if isOwner(uid)
          && isBoundedList(50);

        allow create, update, delete: if isVerifiedUser(uid);
      }
    }

    // Token balances are controlled by the backend.
    match /userTokens/{uid} {
      allow get: if isOwner(uid);

      allow list, create, update, delete: if false;
    }

    // Community modes.
    match /community_modes/{modeId} {
      allow get: if isSignedIn();

      allow list: if isSignedIn()
        && isBoundedList(100);

      allow create: if isSignedIn()
        && request.auth.token.email_verified == true
        && request.resource.data.authorId == request.auth.uid;

      allow update: if isSignedIn()
        && request.auth.token.email_verified == true
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId;

      allow delete: if isSignedIn()
        && request.auth.token.email_verified == true
        && resource.data.authorId == request.auth.uid;
    }

    // Team membership and shared projects are controlled by the backend.
    match /teams/{teamId} {
      allow get, list, create, update, delete: if false;

      match /{document=**} {
        allow get, list, create, update, delete: if false;
      }
    }

    // Stripe extension and backend records.
    // Browsers may read their own records but cannot create or modify them.
    match /customers/{uid} {
      allow get: if isOwner(uid);

      allow list, create, update, delete: if false;

      match /checkout_sessions/{sessionId} {
        allow get: if isOwner(uid);

        allow list, create, update, delete: if false;
      }

      match /portal_sessions/{sessionId} {
        allow get: if isOwner(uid);

        allow list, create, update, delete: if false;
      }

      match /subscriptions/{subscriptionId} {
        allow get: if isOwner(uid);

        allow list, create, update, delete: if false;
      }

      match /payments/{paymentId} {
        allow get: if isOwner(uid);

        allow list, create, update, delete: if false;
      }
    }

    // Stripe product catalogue.
    match /products/{productId} {
      allow get, list: if true;

      allow create, update, delete: if false;

      match /prices/{priceId} {
        allow get, list: if true;

        allow create, update, delete: if false;
      }

      match /tax_rates/{taxRateId} {
        allow get, list: if true;

        allow create, update, delete: if false;
      }
    }

    // Internal backend-only collections.
    match /_productAnalyticsEvents/{eventId} {
      allow read, write: if false;
    }

    match /aiTelemetryEvents/{eventId} {
      allow read, write: if false;
    }

    match /_jobs/{jobId} {
      allow read, write: if false;
    }

    // Prompt 3 durable task runtime namespaces are backend-only.
    match /_tasks/{taskId} {
      allow read, write: if false;

      match /{subcollection}/{docId} {
        allow read, write: if false;

        match /{nested}/{nestedId} {
          allow read, write: if false;
        }
      }
    }

    match /_operations/{operationId} {
      allow read, write: if false;

      match /{subcollection}/{docId} {
        allow read, write: if false;
      }
    }

    match /_taskOutbox/{messageId} {
      allow read, write: if false;
    }

    match /_taskReservations/{reservationId} {
      allow read, write: if false;
    }

    match /_taskJobProjectionInbox/{receiptId} {
      allow read, write: if false;
    }

    match /_capabilitySnapshots/{snapshotId} {
      allow read, write: if false;
    }

    match /_agentContextSnapshots/{snapshotId} {
      allow read, write: if false;
    }

    match /_studioCommands/{commandId} {
      allow read, write: if false;
    }

    match /_migrationControl/{migrationId} {
      allow read, write: if false;

      match /{subcollection}/{docId} {
        allow read, write: if false;

        match /{nested}/{nestedId} {
          allow read, write: if false;
        }
      }
    }

    match /_stream_sessions/{sessionId} {
      allow read, write: if false;
    }

    // Deny every collection that was not explicitly declared above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
