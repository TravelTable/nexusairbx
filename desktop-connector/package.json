{
  "name": "nexusrbx-desktop-connector",
  "version": "0.2.5",
  "private": true,
  "author": "NexusRBX",
  "type": "module",
  "description": "Customer desktop companion for NexusRBX Studio MCP",
  "main": "dist/main.js",
  "scripts": {
    "version:check": "node scripts/check-release-version.mjs",
    "build": "npm run version:check && node scripts/clean-dist.mjs && npm --prefix ../local-connector run build && tsc -p tsconfig.json && tsc -p tsconfig.preload.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "tsx --test test/*.test.ts && vitest run",
    "check": "npm run typecheck && npm test && npm run build",
    "package": "npm run build && electron-builder --publish never",
    "package:mac": "npm run build && electron-builder --mac --universal --publish never",
    "package:win": "npm run build && electron-builder --win nsis --x64 --publish never",
    "verify:mac-universal": "node scripts/verify-macos-universal.mjs release/mac-universal/NexusRBX\\ Connector.app",
    "release:publish": "node scripts/publish-release-feed.mjs release",
    "checksums": "node scripts/write-checksums.mjs release",
    "checksums:verify": "node scripts/verify-checksums.mjs release"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vercel/blob": "^2.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.468.0",
    "nexusrbx-local-connector": "file:../local-connector",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.nexusrbx.companion",
    "productName": "NexusRBX Connector",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "protocols": [
      {
        "name": "NexusRBX pairing",
        "schemes": [
          "nexusrbx"
        ]
      }
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://downloads.nexusrbx.com/connector"
      }
    ],
    "afterSign": "scripts/notarize.mjs",
    "mac": {
      "icon": "../public/logo.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "icon": "../public/logo.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    }
  }
}
