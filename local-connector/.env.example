NEXUSRBX_API_URL=https://api.nexusrbx.com

# Prefer entering the short-lived pairing code interactively.
# NEXUSRBX_PAIR_CODE=

# The macOS and Windows launch commands are detected automatically.
# Set these only for a non-standard Roblox Studio installation.
# NEXUSRBX_MCP_COMMAND=/path/to/StudioMCP
# NEXUSRBX_MCP_ARGS_JSON=[]

# Optional bounded timing controls, in milliseconds.
# NEXUSRBX_REQUEST_TIMEOUT_MS=15000
# NEXUSRBX_HEARTBEAT_MS=15000
# NEXUSRBX_POLL_WAIT_MS=20000

# Sanitized diagnostics only; tokens and authorization values remain redacted.
# NEXUSRBX_VERBOSE=false
