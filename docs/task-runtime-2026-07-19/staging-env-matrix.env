# Prompt 3 staged cutover environment matrix
# Copy one STAGE block into the target Railway/Firebase env. Never enable a later
# stage before the prior stage evidence checklist in staging-cutover-runbook.md
# is signed off. Defaults in backend/.env.example remain fail-closed.

############################
# STAGE 0 — repository gate
############################
TASK_RUNTIME_WRITE_MODE=legacy
TASK_RUNTIME_READ_MODE=legacy
OPERATION_LEDGER_MODE=off
CAPABILITY_SNAPSHOT_MODE=live
TASK_CANONICAL_LEGACY_ADAPTER_ENABLED=false
TASK_OUTBOX_DISPATCH_ENABLED=false
STUDIO_COMMAND_ENVELOPE_V2_ENABLED=false
STUDIO_COMMAND_LEASES_ENABLED=false
ASSET_PLATFORM_READS_ENABLED=false
ASSET_PLATFORM_WRITES_ENABLED=false
ASSET_PLATFORM_AGENT_TOOLS_ENABLED=false
ASSET_PLATFORM_ROBLOX_UPLOAD_ENABLED=false
ASSET_PLATFORM_STUDIO_APPLY_ENABLED=false
TASK_RUNTIME_MIGRATION_APPLY_ENABLED=false
REACT_APP_NEW_TASK_RUNTIME=false
RUN_JOB_WORKER=false

#########################################################
# STAGE 1 — shadow records (legacy sole executor)
# Deploy to a nonproduction tenant only.
#########################################################
# TASK_RUNTIME_WRITE_MODE=dual
# TASK_RUNTIME_READ_MODE=compare
# OPERATION_LEDGER_MODE=observe
# CAPABILITY_SNAPSHOT_MODE=compare
# TASK_CANONICAL_LEGACY_ADAPTER_ENABLED=false
# TASK_OUTBOX_DISPATCH_ENABLED=false
# STUDIO_COMMAND_ENVELOPE_V2_ENABLED=false
# STUDIO_COMMAND_LEASES_ENABLED=false
# REACT_APP_NEW_TASK_RUNTIME=false
# RUN_JOB_WORKER=true

#########################################################
# STAGE 2 — canonical reads for an internal cohort
# Keep legacy execution owner.
#########################################################
# TASK_RUNTIME_WRITE_MODE=dual
# TASK_RUNTIME_READ_MODE=canonical
# OPERATION_LEDGER_MODE=observe
# CAPABILITY_SNAPSHOT_MODE=compare
# REACT_APP_NEW_TASK_RUNTIME=true
# TASK_OUTBOX_DISPATCH_ENABLED=false
# STUDIO_COMMAND_ENVELOPE_V2_ENABLED=false
# STUDIO_COMMAND_LEASES_ENABLED=false
# RUN_JOB_WORKER=true

#########################################################
# STAGE 3 — canonical backend-only execution
# Bounded cohort. Exactly one of adapter OR outbox.
#########################################################
# TASK_RUNTIME_WRITE_MODE=canonical
# TASK_RUNTIME_READ_MODE=canonical
# OPERATION_LEDGER_MODE=enforce
# CAPABILITY_SNAPSHOT_MODE=snapshot
# TASK_CANONICAL_LEGACY_ADAPTER_ENABLED=true
# TASK_OUTBOX_DISPATCH_ENABLED=false
# STUDIO_COMMAND_ENVELOPE_V2_ENABLED=false
# STUDIO_COMMAND_LEASES_ENABLED=false
# REACT_APP_NEW_TASK_RUNTIME=true
# RUN_JOB_WORKER=true
#
# Outbox alternative (mutually exclusive with adapter):
# TASK_CANONICAL_LEGACY_ADAPTER_ENABLED=false
# TASK_OUTBOX_DISPATCH_ENABLED=true

#########################################################
# STAGE 4 — durable Studio transport (dedicated experience)
#########################################################
# STUDIO_COMMAND_ENVELOPE_V2_ENABLED=true
# STUDIO_COMMAND_LEASES_ENABLED=true
# Install only the generated NexusRBXStudioBridge.plugin.lua whose sha256 is
# recorded in the stage evidence log.

#########################################################
# STAGE 5 — Prompt 2 asset tools (after Stage 4 passes)
#########################################################
# ASSET_PLATFORM_READS_ENABLED=true
# ASSET_PLATFORM_AGENT_TOOLS_ENABLED=true
# ASSET_PLATFORM_WRITES_ENABLED=true
# ASSET_PLATFORM_ROBLOX_UPLOAD_ENABLED=false   # enable last, with OAuth+consent
# ASSET_PLATFORM_STUDIO_APPLY_ENABLED=false    # enable after Roblox path proven

#########################################################
# STAGE 6 — cohort expansion / legacy retirement
#########################################################
# Expand only after release thresholds in verification-and-evaluations.md hold
# for the observation window. Retire legacy dispatch last.
