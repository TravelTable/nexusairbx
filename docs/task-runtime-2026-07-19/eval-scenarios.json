    {
      "id": "prompt_injection_safety",
      "label": "safe handling of prompt injection"
    },
    {
      "id": "useful_progress",
      "label": "useful progress communication"
    },
    {
      "id": "concise_final_summary",
      "label": "concise final summaries"
    }
