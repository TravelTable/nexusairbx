{
  "schemaVersion": "nexusrbx-agent-evals-v1",
  "promptVersion": "nexusrbx-agent-v1",
  "description": "Deterministic Prompt 3 evaluation inputs and expected structured outcomes. This corpus does not call a model, Roblox, Studio, a provider, or Firestore.",
  "policy": {
    "maximumClarificationQuestions": 3,
    "completionRequires": "trusted_verification",
    "transportStatesThatAreNotCompletion": [
      "queued",
      "delivered",
      "accepted",
      "executing",
      "acknowledged",
      "outcome_unknown",
      "reconcile_required"
    ],
    "ambiguousExternalOutcome": "reconcile_same_operation_identity",
    "planning": {
      "alwaysInternal": true,
      "visibleWhenToggleEnabled": true,
      "visibleWhenExplicitlyRequested": true
    }
  },
  "prompt2Tools": [
    "search_assets",
    "resolve_or_create_asset",
    "generate_icon_pack",
    "extend_icon_pack",
    "repair_asset",
    "upload_asset_to_roblox",
    "create_badge",
    "create_game_pass",
    "replace_asset_references"
  ],
  "requiredDimensions": [
    {
      "id": "identity_retention",
      "label": "NexusRBX identity retention"
    },
    {
      "id": "correct_project_selection",
      "label": "correct project selection"
    },
    {
      "id": "correct_universe_selection",
      "label": "correct universe selection"
    },
    {
      "id": "correct_place_selection",
      "label": "correct place selection"
    },
    {
      "id": "correct_studio_session_selection",
      "label": "correct Studio session selection"
    },
    {
      "id": "connected_capability_awareness",
      "label": "awareness of connected Roblox capabilities"
    },
    {
      "id": "unavailable_capability_awareness",
      "label": "awareness of unavailable capabilities"
    },
    {
      "id": "correct_asset_id_retrieval",
      "label": "correct asset-ID retrieval"
    },
    {
      "id": "correct_tool_selection",
      "label": "correct tool selection"
    },
    {
      "id": "avoid_unnecessary_questions",
      "label": "avoidance of unnecessary questions"
    },
    {
      "id": "clarify_unclear_ownership",
      "label": "clarification when ownership is unclear"
    },
    {
      "id": "planning_toggle",
      "label": "planning-toggle behaviour"
    },
    {
      "id": "internal_planning",
      "label": "internal planning behaviour"
    },
    {
      "id": "task_amendment",
      "label": "task amendment"
    },
    {
      "id": "interruption_recovery",
      "label": "recovery after interruption"
    },
    {
      "id": "nonduplicate_retry",
      "label": "non-duplication after retry"
    },
    {
      "id": "refuse_unverified_success",
      "label": "refusal to claim unverified success"
